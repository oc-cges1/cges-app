# ==========================================
# DEPENDENCIAS
# ==========================================
node_modules/
**/node_modules/
.pnpm-store/
jspm_packages/

# ==========================================
# BUILD / PRODUCCIÓN
# ==========================================
dist/
build/
out/
.next/
.cache/
*.tsbuildinfo
*.tlog

# ==========================================
# SEGURIDAD Y VARIABLES DE ENTORNO
# ==========================================
# NUNCA subas estos archivos a GitHub
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env
docker-compose.override.yml

# ==========================================
# ARCHIVOS DE USUARIO / UPLOADS
# ==========================================
# Ignoramos los archivos subidos por el admin para no llenar el repo
# Pero permitimos que la carpeta exista mediante .gitkeep
backend/uploads/*
!backend/uploads/.gitkeep

# ==========================================
# BASE DE DATOS Y PRISMA
# ==========================================
# Ignoramos la base de datos local (si usas SQLite)
*.db
*.db-journal
# El motor generado por Prisma
node_modules/.prisma
# Opcional: Si no quieres subir las migraciones (aunque se recomienda subirlas)
# backend/prisma/migrations/*.sql

# ==========================================
# LOGS Y TEMPORALES
# ==========================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.eslintcache

# ==========================================
# SISTEMA OPERATIVO Y EDITORES
# ==========================================
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================================
# DOCKER
# ==========================================
.docker/
