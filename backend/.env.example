# ── Servidor ──────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ── Base de datos ──────────────────────────────────────────────
DATABASE_URL="postgresql://sisdep_user:sisdep_pass@localhost:5432/sisdep_db?schema=public"

# ── JWT ────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=cambia_esto_por_secreto_aleatorio_minimo_64_caracteres_12345678901234
JWT_REFRESH_SECRET=otro_secreto_diferente_minimo_64_caracteres_aleatorio_abcdefghijklmno
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Bcrypt ─────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Email SMTP ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password_de_gmail
EMAIL_FROM="CGES Sistema <no-reply@cges.gov.co>"

# ── Rate limiting ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
