# .env.production — servidor de producción
# ⚠ NUNCA subir al repositorio

# ── Docker Registry ────────────────────────────────────────────
REGISTRY=ghcr.io/tu-org
TAG=latest

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=sisdep_user
POSTGRES_PASSWORD=genera_password_muy_segura_aqui_minimo_32_chars
POSTGRES_DB=sisdep_db

# ── JWT ────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=pega_aqui_64_caracteres_hex_aleatorios_access_token_secret
JWT_REFRESH_SECRET=pega_aqui_64_caracteres_hex_aleatorios_refresh_token_secret

# ── URLs ───────────────────────────────────────────────────────
FRONTEND_URL=https://tu-dominio.gov.co

# ── Email ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sistema@cges.gov.co
SMTP_PASS=tu_app_password_gmail
EMAIL_FROM="CGES Sistema <no-reply@cges.gov.co>"
